{
  "name": "deliveriq-database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma --name init",
    "prisma:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=prisma/schema.prisma",
    "seed": "tsx seeds/seed.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx seeds/seed.ts"
  },
  "exports": {
    "./import/excel-mapping.js": "./import/excel-mapping.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "bcrypt": "^5.1.1",
    "dayjs": "^1.11.11",
    "deliveriq-shared": "*"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^25.6.0",
    "prisma": "^7.8.0",
    "tsx": "^4.7.2",
    "typescript": "^6.0.3"
  }
}
