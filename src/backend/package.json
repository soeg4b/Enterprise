{
  "name": "deliveriq-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "worker:milestone": "tsx src/workers/milestone.worker.ts",
    "worker:import": "tsx src/workers/import.worker.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.2.0",
    "@prisma/client": "^5.13.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.75.2",
    "dayjs": "^1.11.11",
    "deliveriq-database": "*",
    "deliveriq-shared": "*",
    "exceljs": "^4.4.0",
    "fastify": "^4.27.0",
    "ioredis": "^5.4.1",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.23.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.12.7",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
