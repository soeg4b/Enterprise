# =============================================================================
# DeliverIQ — environment variables (copy to .env and fill in)
# =============================================================================

NODE_ENV=development
PORT=3600
LOG_LEVEL=info

# --- Database ---------------------------------------------------------------
# Host port 3602 -> container 5432
DATABASE_URL=postgresql://deliveriq:deliveriq@localhost:3602/deliveriq?schema=public

# --- Redis (BullMQ + cache) -------------------------------------------------
# Host port 3603 -> container 6379
REDIS_URL=redis://localhost:3603/0

# --- Auth -------------------------------------------------------------------
JWT_SECRET=change-me-to-a-32-byte-random-secret
JWT_REFRESH_SECRET=change-me-to-a-different-32-byte-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_COST=12

# --- Bootstrap admin (first boot) -------------------------------------------
SEED_ADMIN_EMAIL=admin@deliveriq.local
SEED_ADMIN_PASSWORD=ChangeMe!2026
SEED_ADMIN_FULLNAME=System Administrator

# --- CORS allowlist (comma separated) ---------------------------------------
CORS_ORIGINS=http://localhost:3601,http://localhost:3610

# --- S3 / MinIO -------------------------------------------------------------
# MinIO API host port 3604 -> container 9000; Console host port 3605 -> 9001
S3_ENDPOINT=http://localhost:3604
S3_REGION=us-east-1
S3_BUCKET=deliveriq
S3_ACCESS_KEY=deliveriq
S3_SECRET_KEY=deliveriqsecret
S3_FORCE_PATH_STYLE=true

# --- Frontend (Next.js, public) ---------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3600

# --- Mobile (Expo, public) --------------------------------------------------
# Use 10.0.2.2 for Android emulator; replace with LAN IP for physical device
EXPO_PUBLIC_API_URL=http://localhost:3600

# --- Misc -------------------------------------------------------------------
TZ=Asia/Jakarta
MRC_HORIZON_MONTHS=12
