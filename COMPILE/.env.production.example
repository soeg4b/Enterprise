# =============================================================================
# DeliverIQ — PRODUCTION environment template
#
# DO NOT COMMIT a populated copy. Source these from a managed secret store
# (AWS SSM Parameter Store, AWS Secrets Manager, or HashiCorp Vault) and
# inject into the container at runtime — see infra/RUNBOOK.md "secrets".
# =============================================================================

NODE_ENV=production
PORT=3600
LOG_LEVEL=info
TZ=Asia/Jakarta

# --- Database (managed Postgres recommended; least-priv role) ---------------
DATABASE_URL=postgresql://deliveriq_app:__FROM_VAULT__@db.internal:5432/deliveriq?schema=public&sslmode=require

# --- Redis (managed; require TLS in prod) -----------------------------------
REDIS_URL=rediss://:__FROM_VAULT__@redis.internal:6380/0

# --- Auth (32-byte random; rotate quarterly) --------------------------------
JWT_SECRET=__FROM_VAULT__
JWT_REFRESH_SECRET=__FROM_VAULT__
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_COST=12

# --- Bootstrap admin (operator MUST rotate after first boot) ----------------
SEED_ADMIN_EMAIL=admin@deliveriq.example.com
SEED_ADMIN_PASSWORD=__FROM_VAULT__
SEED_ADMIN_FULLNAME=System Administrator

# --- CORS (production hostnames only) ---------------------------------------
CORS_ORIGINS=https://app.deliveriq.example.com

# --- S3 (managed; SSE-KMS recommended) --------------------------------------
S3_ENDPOINT=https://s3.ap-southeast-1.amazonaws.com
S3_REGION=ap-southeast-1
S3_BUCKET=deliveriq-prod
S3_ACCESS_KEY=__FROM_VAULT__
S3_SECRET_KEY=__FROM_VAULT__
S3_FORCE_PATH_STYLE=false

# --- Frontend ---------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.deliveriq.example.com
EXPO_PUBLIC_API_URL=https://api.deliveriq.example.com

# --- Hardening --------------------------------------------------------------
# Comma-separated CIDRs the API should trust as proxy peers (LB only).
TRUST_PROXY=10.0.0.0/8
# Excel parser caps (SEC-NEW-07).
IMPORT_MAX_ROWS=200000
IMPORT_MAX_CELL_BYTES=32768

# --- Misc -------------------------------------------------------------------
MRC_HORIZON_MONTHS=12
