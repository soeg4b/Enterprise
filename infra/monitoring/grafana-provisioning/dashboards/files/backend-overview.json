{
  "annotations": { "list": [] },
  "title": "DeliverIQ — Backend Overview",
  "uid": "deliveriq-backend",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "tags": ["deliveriq", "backend"],
  "templating": { "list": [] },
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total{job=\"deliveriq-backend\"}[5m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "P95 latency (s)",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket{job=\"deliveriq-backend\"}[5m])))",
          "legendFormat": "p95 {{route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error rate (5xx %)",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{job=\"deliveriq-backend\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"deliveriq-backend\"}[5m]))",
          "legendFormat": "5xx %"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "BullMQ queue depth",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "bullmq_queue_waiting_jobs",
          "legendFormat": "{{queue}}"
        }
      ]
    }
  ]
}
